[font]
size = 16.0

[font.normal]
family = "Inconsolata"
style = "Regular"

[font.bold]
family = "Inconsolata"
style = "Bold"

[font.italic]
family = "Inconsolata"
style = "Light"

[colors.bright]
black = "0x282c34"
blue = "0x61afef"
cyan = "0x56b6c2"
green = "0x98c379"
magenta = "0xc678dd"
red = "0xe06c75"
white = "0xdcdfe4"
yellow = "0xe5c07b"

[colors.normal]
black = "0x181a1f"
blue = "0x61afef"
cyan = "0x56b6c2"
green = "0x98c379"
magenta = "0xc678dd"
red = "0xe06c75"
white = "0xdcdfe4"
yellow = "0xe5c07b"

[colors.primary]
background = "0x181a1f"
foreground = "0xdcdfe4"
